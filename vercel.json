{
  "buildCommand": "cd pretrained_test/frontend && npm install && npm run build",
  "outputDirectory": "pretrained_test/frontend/dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
